<script>
// ── AUTH ──────────────────────────────────────────────
const OWNER_EMAIL = "northchicagorp0@gmail.com";
const OWNER_PASS  = "HelloOwner?!1";
let currentUser = null;

function doLogin() {
  const email = document.getElementById("loginEmail").value.trim().toLowerCase();
  const pass  = document.getElementById("loginPass").value;
  const err   = document.getElementById("authErr");
  if (!email || !pass) { showErr("Please enter your email and password."); return; }
  // Owner check
  if (email === OWNER_EMAIL.toLowerCase() && pass === OWNER_PASS) {
    currentUser = { email: OWNER_EMAIL, role: "owner" };
    setupApp();
    return;
  }
  // Simulate user login (any other email + any password ≥6 chars)
  if (pass.length >= 6) {
    currentUser = { email, role: "user" };
    setupApp();
    return;
  }
  showErr("Incorrect email or password. Please try again.");
}

function showErr(msg) {
  const el = document.getElementById("authErr");
  el.textContent = msg;
  el.style.display = "block";
}

function setupApp() {
  document.getElementById("authWrap").style.display = "none";
  document.getElementById("appWrap").style.display  = "flex";
  const isOwner = currentUser.role === "owner";
  // Sidebar name/plan
  document.getElementById("sidebarName").textContent  = isOwner ? "Owner" : currentUser.email.split("@")[0];
  document.getElementById("sidebarPlan").textContent  = isOwner ? "⭐ Owner" : "Free Plan";
  document.getElementById("sidebarAvatar").textContent = currentUser.email[0].toUpperCase();
  document.getElementById("creditsVal").textContent   = isOwner ? "∞" : "47";
  document.getElementById("creditsLabel").textContent = isOwner ? "Owner account" : "credits remaining";
  // Show owner-only nav items
  document.querySelectorAll(".owner-only").forEach(el => el.style.display = isOwner ? "flex" : "none");
  showPage("dashboard");
}

function doLogout() {
  currentUser = null;
  document.getElementById("appWrap").style.display  = "none";
  document.getElementById("authWrap").style.display = "flex";
  document.getElementById("loginEmail").value = "";
  document.getElementById("loginPass").value  = "";
  document.getElementById("authErr").style.display = "none";
}

function showApp() {
  document.getElementById("authWrap").style.display = "none";
  document.getElementById("appWrap").style.display  = "flex";
}

// ── NAVIGATION ────────────────────────────────────────
const pageTitles = {dashboard:"Dashboard",generator:"Video Generator",script:"Script Writer",thumbnail:"Thumbnail Creator",subtitles:"Subtitles & Captions",planner:"Content Planner",tools:"All Tools",pricing:"Pricing",contact:"Contact Us",admin:"Admin Panel"};
function showPage(name) {
  document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
  const pg = document.getElementById("page-"+name);
  if (pg) pg.classList.add("active");
  document.getElementById("pageTitle").textContent = pageTitles[name] || name;
  document.querySelectorAll(".nav-item").forEach(item => {
    if (item.getAttribute("onclick")?.includes(`'${name}'`)) item.classList.add("active");
  });
}

// ── IMAGE PREVIEW ─────────────────────────────────────
function previewImg(input) {
  const preview = document.getElementById("imgPreview");
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.src = e.target.result; preview.style.display = "block"; };
    reader.readAsDataURL(input.files[0]);
  }
}

// ── CLAUDE API ────────────────────────────────────────
async function callClaude(prompt, imgBase64=null) {
  const content = imgBase64
    ? [{ type:"image", source:{ type:"base64", media_type:"image/jpeg", data:imgBase64 } }, { type:"text", text:prompt }]
    : prompt;
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:1000, messages:[{ role:"user", content }] })
  });
  const data = await res.json();
  return data.content?.[0]?.text || "Error generating content.";
}

function setLoading(el) { el.innerHTML = '<span class="spinner"></span> Generating with AI...'; }

function copyText(btn) {
  const text = btn.parentElement.innerText.replace("Copy","").trim();
  navigator.clipboard.writeText(text);
  btn.textContent = "Copied!";
  setTimeout(()=>btn.textContent="Copy",2000);
}

// ── GENERATORS ────────────────────────────────────────
async function generateVideoPrompt() {
  const idea = document.getElementById("videoIdea").value.trim();
  if (!idea) return alert("Please enter a video idea!");
  const style  = document.getElementById("videoStyle").value;
  const plat   = document.getElementById("videoPlatform").value;
  const model  = document.getElementById("videoModel").value;
  const imgEl  = document.getElementById("imgRef");
  const out    = document.getElementById("videoOutput");
  const neg    = document.getElementById("videoNegative");
  setLoading(out); neg.innerHTML = '<span class="spinner"></span>';

  let imgBase64 = null;
  if (imgEl.files[0]) {
    imgBase64 = await new Promise(res => {
      const r = new FileReader();
      r.onload = e => res(e.target.result.split(",")[1]);
      r.readAsDataURL(imgEl.files[0]);
    });
  }

  const prompt = `You are an expert AI video prompt engineer. Create an optimized video generation prompt for "${model}" based on:
Idea: ${idea}
Style: ${style}
Platform: ${plat}
${imgBase64 ? "An image reference has been provided — incorporate its visual style, colors, and mood." : ""}

Return EXACTLY this format:
PROMPT:
[Detailed 3-5 sentence cinematic video prompt with camera movement, lighting, atmosphere, subject details, motion]

NEGATIVE PROMPT:
[Things to avoid: blur, artifacts, bad quality etc.]`;

  const result = await callClaude(prompt, imgBase64);
  const pm = result.match(/PROMPT:\n([\s\S]+?)(?=NEGATIVE PROMPT:|$)/);
  const nm = result.match(/NEGATIVE PROMPT:\n([\s\S]+)/);
  out.innerHTML = (pm?.[1]?.trim()||result) + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
  neg.innerHTML = (nm?.[1]?.trim()||"") + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
}

async function generateScript() {
  const topic = document.getElementById("scriptTopic").value.trim();
  if (!topic) return alert("Please enter a topic!");
  const type = document.getElementById("scriptType").value;
  const tone = document.getElementById("scriptTone").value;
  const aud  = document.getElementById("scriptAudience").value || "general audience";
  const out  = document.getElementById("scriptOutput");
  setLoading(out);
  const result = await callClaude(`Write a complete ${type} video script about: "${topic}"\nTone: ${tone}\nAudience: ${aud}\n\nStructure:\n🎣 HOOK (first 5-10 seconds)\n📖 INTRO\n📚 BODY (with [B-ROLL: description] cues)\n🎯 CALL TO ACTION\n\nMake it natural and optimized for retention.`);
  out.innerHTML = result.replace(/\n/g,"<br>") + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
}

async function generateThumbnail() {
  const topic = document.getElementById("thumbTopic").value.trim();
  if (!topic) return alert("Please enter a topic!");
  const style = document.getElementById("thumbStyle").value;
  const color = document.getElementById("thumbColor").value || "bold contrasting colors";
  const out   = document.getElementById("thumbOutput");
  setLoading(out);
  const result = await callClaude(`You are a YouTube thumbnail expert. Create 3 distinct thumbnail concepts for: "${topic}"\nStyle: ${style}\nColors: ${color}\n\nFor each:\n- LAYOUT: visual composition\n- TEXT OVERLAY: max 5 words\n- BACKGROUND: scene description\n- EMOTION: feeling triggered\n- AI IMAGE PROMPT: for Midjourney/DALL-E`);
  out.innerHTML = result.replace(/\n/g,"<br>") + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
}

async function generateSubtitles() {
  const script = document.getElementById("subScript").value.trim();
  if (!script) return alert("Please paste a script first!");
  const style    = document.getElementById("subStyle").value;
  const length   = document.getElementById("subLength").value;
  const emphasis = document.getElementById("subEmphasis").value;
  const out      = document.getElementById("subOutput");
  setLoading(out);
  const result = await callClaude(`Format this script as ${style} subtitles for a ${length} video.\n${emphasis ? `Emphasize/highlight these words: ${emphasis}` : ""}\nScript: ${script}\n\nCreate subtitle blocks with [MM:SS] timestamps. Keep text punchy. For viral/TikTok style: 1-3 words per line, ALL CAPS. For SRT: include index numbers. Ready to import into CapCut or Premiere.`);
  out.innerHTML = result.replace(/\n/g,"<br>") + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
}

async function generatePlan() {
  const niche = document.getElementById("planNiche").value.trim();
  if (!niche) return alert("Please enter your niche!");
  const freq = document.getElementById("planFreq").value;
  const mix  = document.getElementById("planMix").value;
  const out  = document.getElementById("planOutput");
  setLoading(out);
  const result = await callClaude(`Create a 30-day content calendar for a ${niche} YouTube channel.\nFrequency: ${freq}\nContent mix: ${mix}\n\nFor each video: 📅 Day, 🎬 Title (clickable+SEO), 🎣 Hook idea, #️⃣ 3 hashtags, 📏 Format. Group by weeks. Make titles viral.`);
  out.innerHTML = result.replace(/\n/g,"<br>") + '<button class="copy-btn" onclick="copyText(this)">Copy</button>';
}

// ── CONTACT FORM (Web3Forms) ──────────────────────────
async function submitContact(e) {
  e.preventDefault();
  const btn = document.getElementById("contactBtn");
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Sending...';
  const form = document.getElementById("contactForm");
  const data = new FormData(form);
  try {
    const res = await fetch("https://api.web3forms.com/submit", { method:"POST", body:data });
    const json = await res.json();
    if (json.success) {
      form.reset();
      document.getElementById("contactSuccess").style.display = "block";
      btn.innerHTML = "Send Message";
      btn.disabled = false;
    } else {
      btn.innerHTML = "Send Message";
      btn.disabled = false;
      alert("Something went wrong. Please try again.");
    }
  } catch {
    btn.innerHTML = "Send Message";
    btn.disabled = false;
    alert("Network error. Please try again.");
  }
}
</script>
</body>
</html>
