<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SlopAI — AI Video Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:#080b14;--surface:#0e1220;--surface2:#161c2e;--border:#1e2740;
  --accent:#4f6ef7;--accent2:#a855f7;--accent3:#06d6a0;--text:#e8ecf4;
  --muted:#7a8399;--gold:#f5c842;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* AUTH */
#authWrap{display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--bg);}
.auth-box{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:40px 36px;width:380px;max-width:95vw;}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:28px;justify-content:center;}
.auth-logo-icon{width:42px;height:42px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.auth-logo-text{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.auth-title{font-family:'Syne',sans-serif;font-weight:700;font-size:20px;margin-bottom:6px;text-align:center;}
.auth-sub{font-size:13px;color:var(--muted);text-align:center;margin-bottom:24px;}
.auth-field{margin-bottom:14px;}
.auth-field label{font-size:12px;font-weight:600;color:var(--muted);display:block;margin-bottom:6px;letter-spacing:.5px;text-transform:uppercase;}
.auth-field input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color .18s;}
.auth-field input:focus{border-color:var(--accent);}
.auth-err{color:#f7574f;font-size:12.5px;margin-bottom:12px;display:none;background:rgba(247,87,79,.1);padding:8px 12px;border-radius:8px;border:1px solid rgba(247,87,79,.2);}
.btn-auth{width:100%;padding:12px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border:none;border-radius:10px;font-family:'Syne',sans-serif;font-weight:700;font-size:15px;cursor:pointer;transition:opacity .18s;}
.btn-auth:hover{opacity:.88;}
.auth-note{font-size:11px;color:var(--muted);text-align:center;margin-top:16px;}

/* APP */
#appWrap{display:none;min-height:100vh;}
.sidebar{width:230px;min-height:100vh;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;z-index:100;}
.logo{padding:20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;}
.logo-text{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.logo-badge{font-size:9px;background:var(--accent3);color:#000;padding:2px 6px;border-radius:20px;font-weight:700;margin-left:auto;}
.nav{padding:14px 10px;flex:1;}
.nav-label{font-size:10px;font-weight:600;letter-spacing:1.5px;color:var(--muted);padding:8px 10px 4px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;cursor:pointer;color:var(--muted);font-size:13.5px;font-weight:400;transition:all .18s;margin-bottom:2px;position:relative;}
.nav-item:hover{background:var(--surface2);color:var(--text);}
.nav-item.active{background:linear-gradient(90deg,rgba(79,110,247,.18),rgba(168,85,247,.10));color:var(--text);font-weight:500;}
.nav-icon{font-size:16px;width:22px;text-align:center;}
.nav-badge{margin-left:auto;font-size:9px;background:var(--accent);color:#fff;padding:2px 6px;border-radius:20px;font-weight:600;}
.owner-only{display:none;}
.sidebar-footer{padding:14px;border-top:1px solid var(--border);}
.user-card{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:var(--surface2);}
.avatar{width:30px;height:30px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;}
.user-name{font-size:12.5px;font-weight:600;}
.user-plan{font-size:10px;color:var(--gold);font-weight:600;}
.logout-btn{margin-top:8px;width:100%;padding:7px;background:transparent;border:1px solid var(--border);border-radius:8px;color:var(--muted);font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .18s;}
.logout-btn:hover{border-color:#f7574f;color:#f7574f;}

.main{margin-left:230px;flex:1;min-height:100vh;}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 30px;border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:50;}
.page-title{font-family:'Syne',sans-serif;font-weight:700;font-size:20px;}
.topbar-right{display:flex;gap:10px;align-items:center;}
.btn{padding:8px 18px;border-radius:8px;border:none;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all .18s;}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;}
.btn-primary:hover{opacity:.88;transform:translateY(-1px);}
.btn-ghost{background:var(--surface2);color:var(--text);border:1px solid var(--border);}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);}
.content{padding:28px 30px;}

.page{display:none;}
.page.active{display:block;}

label{font-size:12.5px;font-weight:500;color:var(--muted);display:block;margin-bottom:6px;}
input,textarea,select{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13.5px;outline:none;transition:border-color .18s;}
input:focus,textarea:focus,select:focus{border-color:var(--accent);}
textarea{resize:vertical;min-height:90px;}
select option{background:var(--surface2);}
.field{margin-bottom:16px;}

.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px;transition:border-color .2s;}
.card:hover{border-color:rgba(79,110,247,.3);}
.card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:6px;}
.card-desc{font-size:13px;color:var(--muted);margin-bottom:18px;}

.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;}

.output-box{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:16px;font-size:13.5px;line-height:1.75;color:var(--text);min-height:120px;white-space:pre-wrap;position:relative;}
.output-placeholder{color:var(--muted);font-style:italic;}
.copy-btn{position:absolute;top:10px;right:10px;background:var(--border);border:none;color:var(--muted);font-size:11px;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;}
.copy-btn:hover{background:var(--accent);color:#fff;}

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px 20px;}
.stat-label{font-size:11.5px;color:var(--muted);font-weight:500;margin-bottom:8px;}
.stat-value{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;}
.stat-change{font-size:11.5px;color:var(--accent3);margin-top:4px;}

.tool-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.tool-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:20px;cursor:pointer;transition:all .2s;text-align:center;}
.tool-card:hover{border-color:var(--accent);transform:translateY(-2px);background:var(--surface2);}
.tool-icon{font-size:28px;margin-bottom:10px;display:block;}
.tool-name{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;margin-bottom:4px;}
.tool-desc{font-size:12px;color:var(--muted);}
.tool-tag{display:inline-block;font-size:10px;padding:2px 8px;border-radius:20px;margin-top:8px;font-weight:600;}
.tag-free{background:rgba(6,214,160,.15);color:var(--accent3);}
.tag-pro{background:rgba(245,200,66,.15);color:var(--gold);}
.tag-new{background:rgba(79,110,247,.2);color:var(--accent);}

.video-row{display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--border);}
.video-thumb{width:80px;height:48px;border-radius:8px;background:linear-gradient(135deg,var(--surface2),var(--border));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;border:1px solid var(--border);}
.video-info{flex:1;}
.video-title{font-size:13.5px;font-weight:500;margin-bottom:3px;}
.video-meta{font-size:11.5px;color:var(--muted);}
.status-badge{font-size:10.5px;font-weight:600;padding:3px 10px;border-radius:20px;}
.status-done{background:rgba(6,214,160,.15);color:var(--accent3);}
.status-processing{background:rgba(79,110,247,.15);color:var(--accent);}

.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:10px;}
.plan-card{border-radius:18px;padding:28px 24px;border:1px solid var(--border);position:relative;background:var(--surface);}
.plan-card.featured{border-color:var(--accent);background:linear-gradient(160deg,rgba(79,110,247,.12),rgba(168,85,247,.08));}
.plan-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,var(--accent),var(--accent2));color:#fff;font-size:11px;font-weight:700;padding:4px 14px;border-radius:20px;}
.plan-name{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;margin-bottom:6px;}
.plan-price{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;}
.plan-price span{font-size:15px;color:var(--muted);font-weight:400;}
.plan-desc{font-size:12.5px;color:var(--muted);margin:10px 0 18px;}
.plan-feature{display:flex;align-items:center;gap:8px;font-size:13px;margin-bottom:10px;}
.plan-feature::before{content:'✓';color:var(--accent3);font-weight:700;}

.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.section-title{font-family:'Syne',sans-serif;font-weight:700;font-size:17px;}
.gradient-text{background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.welcome-banner{background:linear-gradient(120deg,rgba(79,110,247,.15),rgba(168,85,247,.10));border:1px solid rgba(79,110,247,.25);border-radius:18px;padding:28px 30px;margin-bottom:24px;display:flex;align-items:center;gap:20px;}
.welcome-text h2{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;margin-bottom:6px;}
.welcome-text p{color:var(--muted);font-size:14px;}
.welcome-emoji{font-size:52px;}
.divider{border:none;border-top:1px solid var(--border);margin:20px 0;}

/* Image ref upload */
.img-upload-area{border:2px dashed var(--border);border-radius:12px;padding:20px;text-align:center;cursor:pointer;transition:border-color .2s;margin-bottom:16px;}
.img-upload-area:hover{border-color:var(--accent);}
.img-upload-area input{display:none;}
.img-preview{width:100%;max-height:160px;object-fit:cover;border-radius:8px;margin-top:10px;display:none;}
.img-upload-label{font-size:13px;color:var(--muted);}

/* Admin panel */
.admin-table{width:100%;border-collapse:collapse;font-size:13px;}
.admin-table th{text-align:left;padding:10px 14px;border-bottom:1px solid var(--border);color:var(--muted);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.5px;}
.admin-table td{padding:12px 14px;border-bottom:1px solid var(--border);}
.admin-tag{font-size:10.5px;padding:2px 8px;border-radius:20px;font-weight:600;}
.admin-tag-owner{background:rgba(245,200,66,.15);color:var(--gold);}
.admin-tag-user{background:rgba(79,110,247,.15);color:var(--accent);}

/* Contact form */
.contact-success{display:none;background:rgba(6,214,160,.1);border:1px solid rgba(6,214,160,.3);border-radius:10px;padding:14px 18px;color:var(--accent3);font-size:13.5px;margin-top:14px;}

/* Spinner */
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:8px;}
@keyframes spin{to{transform:rotate(360deg);}}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:10px;}
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="authWrap">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="auth-logo-icon">🎬</div>
      <span class="auth-logo-text">SlopAI</span>
    </div>
    <div class="auth-title">Welcome back</div>
    <div class="auth-sub">Sign in to your SlopAI account</div>
    <div class="auth-err" id="authErr">Incorrect email or password. Please try again.</div>
    <div class="auth-field">
      <label>Email</label>
      <input type="email" id="loginEmail" placeholder="you@example.com" onkeydown="if(event.key==='Enter')doLogin()"/>
    </div>
    <div class="auth-field">
      <label>Password</label>
      <input type="password" id="loginPass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"/>
    </div>
    <button class="btn-auth" onclick="doLogin()">Sign In</button>
    <div class="auth-note">Don't have an account? <span style="color:var(--accent);cursor:pointer" onclick="showPage('pricing');showApp()">View pricing →</span></div>
  </div>
</div>

<!-- APP -->
<div id="appWrap" style="display:flex;">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="logo">
      <div class="logo-icon">🎬</div>
      <span class="logo-text">SlopAI</span>
      <span class="logo-badge">BETA</span>
    </div>
    <nav class="nav">
      <div class="nav-label">Studio</div>
      <div class="nav-item active" onclick="showPage('dashboard')"><span class="nav-icon">⚡</span> Dashboard</div>
      <div class="nav-item" onclick="showPage('generator')"><span class="nav-icon">🎬</span> Video Generator</div>
      <div class="nav-item" onclick="showPage('script')"><span class="nav-icon">📝</span> Script Writer</div>
      <div class="nav-item" onclick="showPage('thumbnail')"><span class="nav-icon">🖼️</span> Thumbnails</div>
      <div class="nav-item" onclick="showPage('subtitles')"><span class="nav-icon">💬</span> Subtitles & Captions</div>
      <div class="nav-label">Growth</div>
      <div class="nav-item" onclick="showPage('planner')"><span class="nav-icon">📅</span> Content Planner</div>
      <div class="nav-item" onclick="showPage('tools')"><span class="nav-icon">🔧</span> All Tools <span class="nav-badge">12</span></div>
      <div class="nav-label">Account</div>
      <div class="nav-item" onclick="showPage('pricing')"><span class="nav-icon">💎</span> Pricing</div>
      <div class="nav-item" onclick="showPage('contact')"><span class="nav-icon">✉️</span> Contact Us</div>
      <div class="nav-item owner-only" onclick="showPage('admin')"><span class="nav-icon">🛡️</span> Admin Panel</div>
    </nav>
    <div class="sidebar-footer">
      <div class="user-card">
        <div class="avatar" id="sidebarAvatar">U</div>
        <div>
          <div class="user-name" id="sidebarName">User</div>
          <div class="user-plan" id="sidebarPlan">Free Plan</div>
        </div>
      </div>
      <button class="logout-btn" onclick="doLogout()">← Log out</button>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">
    <div class="topbar">
      <span class="page-title" id="pageTitle">Dashboard</span>
      <div class="topbar-right">
        <button class="btn btn-ghost" onclick="showPage('tools')">🔧 All Tools</button>
        <button class="btn btn-primary" onclick="showPage('generator')">+ New Video</button>
      </div>
    </div>

    <div class="content">

      <!-- DASHBOARD -->
      <div class="page active" id="page-dashboard">
        <div class="welcome-banner">
          <div class="welcome-emoji">🚀</div>
          <div class="welcome-text">
            <h2>Welcome to <span class="gradient-text">SlopAI Studio</span></h2>
            <p>Your AI-powered video creation platform. Generate scripts, prompts, thumbnails and content plans in seconds.</p>
          </div>
          <button class="btn btn-primary" onclick="showPage('generator')" style="margin-left:auto;white-space:nowrap">Create Video →</button>
        </div>
        <div class="stats-row">
          <div class="stat-card"><div class="stat-label">Videos Generated</div><div class="stat-value">24</div><div class="stat-change">↑ 8 this week</div></div>
          <div class="stat-card"><div class="stat-label">Scripts Written</div><div class="stat-value">61</div><div class="stat-change">↑ 12 this week</div></div>
          <div class="stat-card"><div class="stat-label">Thumbnails Made</div><div class="stat-value">38</div><div class="stat-change">↑ 5 this week</div></div>
          <div class="stat-card"><div class="stat-label">Credits Left</div><div class="stat-value" id="creditsVal" style="color:var(--accent3)">∞</div><div class="stat-change" id="creditsLabel" style="color:var(--gold)">Loading...</div></div>
        </div>
        <div class="grid-2" style="gap:20px">
          <div class="card">
            <div class="section-header"><div class="card-title">Recent Generations</div></div>
            <div class="video-row"><div class="video-thumb">🌆</div><div class="video-info"><div class="video-title">City at night — cinematic drone shot</div><div class="video-meta">Kling AI · 5s · 2 hours ago</div></div><span class="status-badge status-done">Done</span></div>
            <div class="video-row"><div class="video-thumb">🌊</div><div class="video-info"><div class="video-title">Ocean waves at sunset — slow motion</div><div class="video-meta">Runway · 4s · Yesterday</div></div><span class="status-badge status-done">Done</span></div>
            <div class="video-row"><div class="video-thumb">🤖</div><div class="video-info"><div class="video-title">AI robot walking in futuristic city</div><div class="video-meta">Kling AI · 5s · 2 days ago</div></div><span class="status-badge status-processing">Processing</span></div>
          </div>
          <div class="card">
            <div class="card-title" style="margin-bottom:16px">Quick Actions</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div class="tool-card" onclick="showPage('generator')" style="text-align:left"><span class="tool-icon">🎬</span><div class="tool-name">New Video</div><div class="tool-desc">Text → Video prompt</div></div>
              <div class="tool-card" onclick="showPage('script')" style="text-align:left"><span class="tool-icon">📝</span><div class="tool-name">Write Script</div><div class="tool-desc">AI script writer</div></div>
              <div class="tool-card" onclick="showPage('thumbnail')" style="text-align:left"><span class="tool-icon">🖼️</span><div class="tool-name">Thumbnail</div><div class="tool-desc">AI concepts</div></div>
              <div class="tool-card" onclick="showPage('subtitles')" style="text-align:left"><span class="tool-icon">💬</span><div class="tool-name">Subtitles</div><div class="tool-desc">Auto-format captions</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- VIDEO GENERATOR -->
      <div class="page" id="page-generator">
        <div class="grid-2" style="gap:22px;align-items:start">
          <div>
            <div class="card" style="margin-bottom:18px">
              <div class="card-title">🎬 AI Video Prompt Generator</div>
              <div class="card-desc">Describe your idea — we'll craft the perfect prompt for Kling, Runway, or Sora</div>
              <div class="field">
                <label>Your video idea</label>
                <textarea id="videoIdea" placeholder="e.g. A futuristic city at night with flying cars and neon lights"></textarea>
              </div>

              <!-- Image Reference Upload -->
              <div class="field">
                <label>Image Reference (optional)</label>
                <div class="img-upload-area" onclick="document.getElementById('imgRef').click()">
                  <input type="file" id="imgRef" accept="image/*" onchange="previewImg(this)"/>
                  <div class="img-upload-label">📎 Click to upload a reference image<br><span style="font-size:11px;color:var(--muted)">JPG, PNG, WEBP — helps AI match your visual style</span></div>
                  <img id="imgPreview" class="img-preview"/>
                </div>
              </div>

              <div class="grid-2" style="gap:12px">
                <div class="field">
                  <label>Video style</label>
                  <select id="videoStyle">
                    <option>Cinematic</option><option>Realistic</option><option>Anime / Animated</option><option>Vintage / Film</option><option>Documentary</option><option>Music video</option>
                  </select>
                </div>
                <div class="field">
                  <label>Platform</label>
                  <select id="videoPlatform">
                    <option>YouTube (16:9)</option><option>TikTok / Shorts (9:16)</option><option>Instagram Reel (9:16)</option><option>Square (1:1)</option>
                  </select>
                </div>
              </div>
              <div class="field">
                <label>Target AI model</label>
                <select id="videoModel">
                  <option>Kling AI</option><option>Runway Gen-3</option><option>Sora (OpenAI)</option><option>Google Veo 2</option><option>Hailuo</option>
                </select>
              </div>
              <button class="btn btn-primary" onclick="generateVideoPrompt()" style="width:100%">✨ Generate Video Prompt</button>
            </div>
          </div>
          <div>
            <div class="card">
              <div class="card-title" style="margin-bottom:14px">Generated Prompt</div>
